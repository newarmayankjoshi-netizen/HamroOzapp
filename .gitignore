# Ignore Firebase admin/service account keys accidentally committed
# These files should live on secure servers or CI secrets, not in the app repo
*adminsdk*.json
serviceAccount*.json
*.key.json

# Specific functions key path (CI will write this file during deploy)
/functions/serviceAccountKey.json
