platform :osx, '10.15'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

 # Workaround: CocoaPods prints repeated "Invalid key/value pair: DART_DEFINES=..."
 # when the `DART_DEFINES` env var contains comma-separated/base64 values.
 # Remove it before CocoaPods runs so `pod install` does not emit those warnings.
 ENV.delete('DART_DEFINES')

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'ephemeral', 'Flutter-Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure \"flutter pub get\" is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Flutter-Generated.xcconfig, then run \"flutter pub get\""
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_macos_podfile_setup

target 'Runner' do
  use_frameworks!

  flutter_install_all_macos_pods File.dirname(File.realpath(__FILE__))
  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  suppress_warnings_for = %w[
    FirebaseAuth
    FirebaseStorage
    FirebaseCrashlytics
    sign_in_with_apple
    gRPC-Core
  ]

  installer.pods_project.targets.each do |target|
    # Some pods still declare 10.11/10.12 which is no longer supported by
    # recent Xcode toolchains. Force everything to a supported minimum.
    target.build_configurations.each do |config|
      config.build_settings['MACOSX_DEPLOYMENT_TARGET'] = '10.15'

      if suppress_warnings_for.include?(target.name)
        config.build_settings['GCC_WARN_INHIBIT_ALL_WARNINGS'] = 'YES'
        config.build_settings['SWIFT_SUPPRESS_WARNINGS'] = 'YES'

        existing = config.build_settings['OTHER_SWIFT_FLAGS']
        existing_flags = case existing
                         when Array
                           existing
                         when String
                           existing.split(' ')
                         else
                           []
                         end
        existing_flags << '$(inherited)' if existing_flags.empty?
        existing_flags << '-suppress-warnings' unless existing_flags.include?('-suppress-warnings')
        config.build_settings['OTHER_SWIFT_FLAGS'] = existing_flags.join(' ')
      end
    end
    # Ensure plugin and aggregate targets don't add duplicate explicit
    # -lc++ / -lz flags which cause "ignoring duplicate libraries" linker
    # warnings. Remove these flags from any OTHER_LDFLAGS entries we find.
    def remove_duplicate_ldflags_from_config(config)
      existing_ldflags = config.build_settings['OTHER_LDFLAGS']
      return unless existing_ldflags

      flags = case existing_ldflags
              when Array
                existing_ldflags
              when String
                existing_ldflags.split(' ')
              else
                []
              end

      # normalize and compact
      flat = flags.flat_map { |f| f.is_a?(String) ? f.split(' ') : [f] }
      filtered = flat.reject { |f| f.nil? }
      # remove problematic duplicates
      filtered.reject! { |f| ['-lc++', '-lz'].include?(f.strip) }

      # write back: if empty remove the key, else set join(' ')
      if filtered.empty?
        config.build_settings.delete('OTHER_LDFLAGS')
      else
        config.build_settings['OTHER_LDFLAGS'] = filtered.join(' ')
      end
    end

    # Apply to pod targets
    target.build_configurations.each do |config|
      remove_duplicate_ldflags_from_config(config)
    end

    # Also apply to aggregate/user project targets to cover runner/project flags
    if installer.respond_to?(:aggregate_targets)
      installer.aggregate_targets.each do |aggregate|
        if aggregate.respond_to?(:user_project) && aggregate.user_project
          aggregate.user_project.native_targets.each do |user_target|
            user_target.build_configurations.each do |cfg|
              remove_duplicate_ldflags_from_config(cfg)
            end
          end
        end
      end
    end
    flutter_additional_macos_build_settings(target)
  end
end
